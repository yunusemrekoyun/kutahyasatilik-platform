// Kütahya Satılık - Dijital Emlak Ofisi
// Prisma 7 schema (SQLite -> kolayca Postgres'e geçirilebilir)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Admin kullanıcısı
// ---------------------------------------------------------------------------
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Emlakçı (danışman) — kayıt olur, admin onaylar, ilan ekleyebilir
// ---------------------------------------------------------------------------
model Agent {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String?
  title        String? // unvan: "Gayrimenkul Danışmanı"
  agency       String? // bağlı olduğu ofis / marka adı
  logo         String? // emlakçının kendi logosu/avatarı (yüklenen görsel URL'i)
  slug         String    @unique
  status       String    @default("pending") // pending | approved | rejected | suspended
  note         String? // admin notu (red/askı sebebi)
  createdAt    DateTime  @default(now())
  approvedAt   DateTime?

  listings Listing[]
  payments Payment[]
  bids     Bid[]

  @@index([status])
}

// ---------------------------------------------------------------------------
// İlan
// ---------------------------------------------------------------------------
model Listing {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String

  propertyType String // daire | arsa | villa | tarla | isyeri | mustakil
  listingType  String @default("sale") // sale | rent
  status       String @default("active") // active | sold | passive

  // Yayın denetimi: emlakçı ilanları admin onayından geçer
  moderationStatus String  @default("approved") // pending | approved | rejected
  note             String? // admin red/moderasyon notu

  // İlanı ekleyen emlakçı (admin eklediyse boş)
  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  price    Int
  currency String @default("TRY")

  district     String // Merkez | Tavşanlı | Simav | Gediz | Emet ...
  neighborhood String?
  address      String?
  lat          Float?
  lng          Float?

  // Konut detayları
  areaGross   Int? // brüt m2
  areaNet     Int? // net m2
  rooms       String? // "3+1"
  floor       String?
  totalFloors Int?
  buildingAge String?
  heating     String?
  furnished   Boolean @default(false)
  inSite      Boolean @default(false)
  balcony     Boolean @default(false)
  parking     Boolean @default(false)

  // Arsa / tarla detayları
  deedStatus   String? // tapu durumu
  zoningStatus String? // imar durumu
  adaNo        String?
  parselNo     String?
  kaks         String? // KAKS / emsal

  // Medya (opsiyonel zengin içerik)
  videoUrl       String? // tanıtım videosu (YouTube/Vimeo)
  droneUrl       String? // drone / havadan görüntü (YouTube/Vimeo)
  virtualTourUrl String? // 360° sanal tur (Matterport, Kuula vb. embed linki)

  // Pazarlama & AI
  featured        Boolean @default(false)
  verified        Boolean @default(false) // tapu/ekspertiz doğrulanmış ilan
  investmentScore Int? // 0-100 (boşsa otomatik hesaplanır)
  valueGrowthPct  Int? // son 3 yıl değer artışı (boşsa ilçe verisinden)
  features        String? // JSON array (string)

  // SEO
  metaTitle       String?
  metaDescription String?

  viewCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images       ListingImage[]
  leads        Lead[]
  events       AnalyticsEvent[]
  priceHistory PriceHistory[]
  favorites    Favorite[]

  @@index([propertyType])
  @@index([district])
  @@index([status])
  @@index([featured])
  @@index([moderationStatus])
  @@index([agentId])
  // Kamu liste/filtre sorguları her zaman moderationStatus+status ile başlar;
  // en sık filtreler district/propertyType, varsayılan sıralama featured+createdAt.
  @@index([moderationStatus, status, district])
  @@index([moderationStatus, status, propertyType])
  @@index([featured, createdAt])
  @@index([price])
}

// ---------------------------------------------------------------------------
// Fiyat geçmişi (her fiyat değişiminde kayıt) — şeffaflık
// ---------------------------------------------------------------------------
model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  price     Int
  createdAt DateTime @default(now())

  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Alıcı talebi / kayıtlı arama — yeni uygun ilanlarla eşleşir
// ---------------------------------------------------------------------------
model BuyerAlert {
  id    String @id @default(cuid())
  name  String
  phone String
  email String?

  propertyType String? // daire | arsa | villa | tarla | isyeri | mustakil
  listingType  String? @default("sale")
  district     String?
  minPrice     Int?
  maxPrice     Int?
  minArea      Int?
  rooms        String?
  note         String?

  status String @default("active") // active | paused | closed

  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  // Hesaba bağlı kayıtlı arama (giriş yapan kullanıcı kaydederse). Anonimse null.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([district])
  @@index([userId])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Lead (Satıcı formu + Randevu / Ekspertiz / Fiyat teklifi / İletişim)
// ---------------------------------------------------------------------------
model Lead {
  id   String @id @default(cuid())
  type String // seller | appointment | expertise | price_offer | contact

  name    String
  phone   String
  email   String?
  message String?

  // Satıcı formu alanları
  district       String?
  neighborhood   String?
  propertyType   String?
  estimatedPrice String?
  photos         String? // JSON array (string)
  lat            Float? // satıcının haritada işaretlediği konum
  lng            Float?

  preferredDate String? // randevu için

  // İlişki (talep bir ilana aitse)
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  status String @default("new") // new | contacted | closed

  // Kaynak / Google Ads takibi
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?
  pagePath    String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Analitik olayları (görüntülenme, telefon/whatsapp tıklama, dönüşüm)
// ---------------------------------------------------------------------------
model AnalyticsEvent {
  id   String @id @default(cuid())
  type String // view | phone_click | whatsapp_click | appointment | expertise | price_offer | seller_lead | conversion

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  district  String?
  pagePath  String?
  referrer  String?
  utmSource String?
  sessionId String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([district])
  @@index([createdAt])
  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Analitik GÜNLÜK ÖZETİ (rollup) — kalıcı arşiv.
// 90 günden eski ham AnalyticsEvent'ler (gün, tip, ilçe) bazında buraya
// özetlenir ve ham tablodan silinir. Dashboard ömür-boyu toplamı = özet + son 90 gün ham.
// Böylece tarih korunur ama AnalyticsEvent sınırsız büyümez.
// ---------------------------------------------------------------------------
model AnalyticsDaily {
  id       String   @id @default(cuid())
  date     DateTime // gün (UTC 00:00)
  type     String
  district String   @default("") // "" = ilçesiz
  count    Int

  @@unique([date, type, district])
  @@index([type])
  @@index([date])
}

// ---------------------------------------------------------------------------
// İlçe verisi (AI analiz şablonlarını besler)
// ---------------------------------------------------------------------------
model District {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  lat Float?
  lng Float?

  investmentScore  Int? // 0-100
  valueGrowth3yPct Int?
  valueGrowth5yPct Int?
  avgPriceDaire    Int? // ortalama daire fiyatı
  avgPriceArsaM2   Int? // ortalama arsa m2 fiyatı

  description     String? // bölge analizi metni
  transportNote   String? // ulaşım / yatırım projeleri notu
  nearbySchools   String? // JSON array (string)
  nearbyHospitals String? // JSON array (string)

  sortOrder Int @default(0)
}

// ---------------------------------------------------------------------------
// Blog yazısı
// ---------------------------------------------------------------------------
model Post {
  id         String  @id @default(cuid())
  slug       String  @unique
  title      String
  excerpt    String? // kısa özet (liste & SEO)
  content    String // WYSIWYG HTML
  coverImage String?
  author     String?
  tags       String? // virgülle ayrılmış etiketler
  status     String  @default("draft") // draft | published

  metaTitle       String?
  metaDescription String?

  viewCount   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([publishedAt])
}

// ---------------------------------------------------------------------------
// İçerik sayfası (Hakkımızda, KVKK, kampanya sayfaları vb.)
// ---------------------------------------------------------------------------
model Page {
  id      String @id @default(cuid())
  slug    String @unique
  title   String
  content String // WYSIWYG HTML
  status  String @default("draft") // draft | published

  showInMenu Boolean @default(false) // footer/menü görünürlüğü
  menuOrder  Int     @default(0)

  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ---------------------------------------------------------------------------
// Müşteri yorumu (ana sayfada gösterilir)
// ---------------------------------------------------------------------------
model Testimonial {
  id        String  @id @default(cuid())
  name      String
  role      String? // "Daire Sahibi · Merkez"
  text      String
  stars     Int     @default(5)
  published Boolean @default(true)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())

  @@index([published])
}

// ---------------------------------------------------------------------------
// Pop-up reklam / duyuru (admin panelinden yönetilir)
// ---------------------------------------------------------------------------
model Popup {
  id        String  @id @default(cuid())
  title     String
  body      String? // açıklama metni
  imageUrl  String?
  linkUrl   String? // tıklanınca gidilecek adres
  linkText  String? // buton metni
  active    Boolean @default(false)
  frequency String  @default("session") // session | daily | always
  delaySec  Int     @default(2) // gösterilmeden önce bekleme (saniye)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

// ---------------------------------------------------------------------------
// Site ayarları (telefon, whatsapp, marka, ana sayfa metinleri vb.) - key/value
// ---------------------------------------------------------------------------
model Setting {
  key   String @id
  value String
}

// ---------------------------------------------------------------------------
// Standart kullanıcı hesabı (Admin/Agent'tan AYRI, ayrı oturum: ks_user)
// Favori senkronu, kayıtlı arama, bildirim kutusu, portföy talebi sahipliği için.
// ÖNEMLİ: Kullanıcı İLAN YAYINLAYAMAZ — yalnız emlakçı/admin ekler (rapor §7).
// ---------------------------------------------------------------------------
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String?
  verifiedAt   DateTime? // e-posta doğrulama (ileride OTP/link ile)
  createdAt    DateTime  @default(now())

  favorites Favorite[]
  alerts    BuyerAlert[]
}

// ---------------------------------------------------------------------------
// Favori (hesaba bağlı) — cihazdan bağımsız senkron. Giriş yoksa localStorage.
// ---------------------------------------------------------------------------
model Favorite {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Merkezi bildirim — tüm roller. İlk sürüm: site-içi (sonra e-posta katmanı).
// recipientId polimorfik: recipientRole'e göre user.id / agent.id'yi gösterir;
// admin için null = tüm adminler. (Tek tabloya FK kurulamadığı için düz alan.)
// ---------------------------------------------------------------------------
model Notification {
  id            String    @id @default(cuid())
  recipientRole String // user | agent | admin
  recipientId   String? // user.id / agent.id; admin için null
  type          String // new_match | new_lead | listing_approved | offer | payment | ad_request | system
  title         String
  body          String?
  link          String? // tıklanınca gidilecek yol
  isRead        Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([recipientRole, recipientId, isRead, createdAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Emlakçı paketi (§5) — ilk sürümde TEK paket. Admin alanları düzenler, yeni
// paket OLUŞTURMAZ. Teklif yapıldığında ad/özellik/fiyat teklife snapshot'lanır.
// ---------------------------------------------------------------------------
model Package {
  id            String   @id @default(cuid())
  name          String   @default("Kurumsal Emlakçı Paketi")
  description   String?
  price         Int      @default(2500) // dönem ücreti (TRY)
  currency      String   @default("TRY")
  interval      String   @default("monthly") // monthly | yearly | one_time
  listingQuota  Int? // null = sınırsız ilan
  featuredQuota Int? // öne çıkarma kotası (null = yok/sınırsız)
  features      String? // JSON array (string) — özellik satırları
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Tahsilat (§6) — ÖDEME ENTEGRASYONU YOK. Ödeme havale/EFT/elden; sistem yalnız
// KAYIT + TAKİP tutar: bekleyen / ödendi / geciken. Emlakçı bazında defter.
// ---------------------------------------------------------------------------
model Payment {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  packageId String? // hangi paket için (snapshot değil, referans)
  amount    Int
  currency  String    @default("TRY")
  period    String? // "Haziran 2026" / "2026-06"
  method    String? // havale | EFT | nakit
  purpose   String    @default("package") // package | listing | featured
  status    String    @default("pending") // pending | paid | overdue
  paidAt    DateTime?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([agentId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Emlakçı başvurusu (§4) — klasik kayıt YOK. /emlakci/kayit hesap açmaz, başvuru
// düşürür. Admin: inceleme→görüşme→teklif→...→aktivasyon. Aktivasyonda Agent oluşur.
// ---------------------------------------------------------------------------
model AgentApplication {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  title      String?
  agency     String?
  experience String? // serbest metin (deneyim/ofis)
  status     String   @default("applied") // applied | reviewing | meeting | offer_sent | accepted | awaiting_payment | rejected | activated
  adminNote  String?
  agentId    String? // aktive edilince oluşan Agent (gevşek referans)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  offers Offer[]

  @@index([status])
}

// ---------------------------------------------------------------------------
// Teklif (§4/§4b) — versiyonlu. Teklif anında paketin adı/fiyat/özellikleri
// SNAPSHOT'lanır; paket sonradan değişse de eski teklif sabit kalır. Emlakçı yalnız
// son (aktif) sürümü görür (e-posta OTP ile); admin tüm geçmişi görür.
// ---------------------------------------------------------------------------
model Offer {
  id               String           @id @default(cuid())
  applicationId    String
  application      AgentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  version          Int
  snapshotName     String
  snapshotPrice    Int
  snapshotFeatures String? // JSON array (string)
  interval         String           @default("monthly")
  status           String           @default("active") // active | superseded | accepted | expired
  validUntil       DateTime?
  viewedAt         DateTime?
  acceptedAt       DateTime?
  viewCount        Int              @default(0)
  createdAt        DateTime         @default(now())

  @@index([applicationId])
}

// ---------------------------------------------------------------------------
// E-posta OTP — teklif görüntüleme doğrulaması (e-posta + tel son 4 + 6 hane kod).
// ---------------------------------------------------------------------------
model EmailOtp {
  id            String   @id @default(cuid())
  applicationId String
  codeHash      String
  expiresAt     DateTime
  attempts      Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([applicationId])
}

// ---------------------------------------------------------------------------
// Portföy fırsatı (§8) — "mülkümü satmak istiyorum" → admin → fırsat → emlakçılar
// komisyon teklifi verir → kazanan seçilir → ilan otomatik oluşur (kazanan emlakçıya).
// ---------------------------------------------------------------------------
model PortfolioOpportunity {
  id             String    @id @default(cuid())
  leadId         String? // kaynak satıcı talebi (varsa)
  userId         String? // talebi yapan kayıtlı kullanıcı (varsa) — seçim yetkisi
  title          String
  description    String?
  district       String?
  propertyType   String?
  estimatedPrice Int?
  areaGross      Int?
  rooms          String?
  biddingEndsAt  DateTime?
  status         String    @default("open") // open | selecting | awarded | listed | closed
  listingId      String? // oluşan ilan
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bids Bid[]

  @@index([status])
  @@index([userId])
}

model Bid {
  id            String               @id @default(cuid())
  opportunityId String
  opportunity   PortfolioOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  agentId       String
  agent         Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  commissionPct Float
  note          String?
  status        String               @default("active") // active | won | lost | withdrawn
  createdAt     DateTime             @default(now())

  @@unique([opportunityId, agentId])
  @@index([opportunityId])
  @@index([agentId])
}

// ---------------------------------------------------------------------------
// Reklam talebi (§12) — self-servis YOK. "Reklam Vermek İstiyorum" CTA → admin kuyruğu.
// ---------------------------------------------------------------------------
model AdRequest {
  id        String   @id @default(cuid())
  name      String
  company   String?
  phone     String
  email     String?
  message   String?
  status    String   @default("new") // new | contacted | accepted | rejected
  createdAt DateTime @default(now())

  @@index([status])
}
